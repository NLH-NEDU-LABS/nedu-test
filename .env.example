# === REQUIRED ===

# Nedu Backend — toàn bộ data (lead, assessment) lưu tại đây
# Local: http://localhost:8080 | Dev: https://api-dev.nedu.vn | Prod: https://api.nedu.vn
NEDU_BACKEND_URL=http://localhost:8080
NEDU_INTERNAL_SECRET=          # lấy từ người bàn giao

# Gemini AI (scoring, email generation)
GEMINI_API_KEY=                # https://aistudio.google.com

# URL của test.nedu.vn (report viewer)
NEXT_PUBLIC_REPORT_BASE_URL=http://localhost:8080   # prod: https://test.nedu.vn

# express = nội bộ/test (làm 1 mạch, nhận report ngay)
# drip    = bên ngoài (chuỗi email 16 ngày — cần AWS SES, bật khi admin yêu cầu)
NEXT_PUBLIC_ASSESSMENT_MODE=express

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cron job protection
CRON_SECRET=                   # bất kỳ string ngẫu nhiên

# === OPTIONAL ===

# AWS SES — chỉ cần khi NEXT_PUBLIC_ASSESSMENT_MODE=drip
AWS_SES_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Bazi geocoding
GEONAMES_USERNAME=             # https://www.geonames.org/login

# Supabase — chỉ cần khi NEXT_PUBLIC_ASSESSMENT_MODE=drip
# Cron email-sequence dùng RPC get_leads_by_day để lấy lead đến ngày gửi.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
