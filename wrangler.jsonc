{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nedu-test-dev",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "placement": {
    "mode": "smart"
  },
  "vars": {
    "NEXT_PUBLIC_ASSESSMENT_MODE": "express",
    "NEXT_PUBLIC_REPORT_BASE_URL": "https://nedu-test-dev.sonle.workers.dev"
  }
}
